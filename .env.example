APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# Precios: opcional en .env; recomendado crear desde /admin/platform/billing
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_YEARLY=
STRIPE_PRICE_TVPIK_1=
STRIPE_PRICE_TVPIK_PACK5=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Integraciones (Stripe, Gemini, Google OAuth, Pre-Alta, TVPik…): configurar en
# Admin → Plataforma → Configuración (/admin/platform/settings).
# Las variables siguientes son solo respaldo opcional si la BD aún no tiene valor.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

WEBNU_FRANCHISE_EMAIL=hola@webnu.es

# Panel plataforma (superadmin): emails separados por coma
SUPER_ADMIN_EMAILS=

# Pre-Alta — captura externa de cartas (staging aislado)
# Cartas públicas: en config/menu_demo.php fill_missing_* debe ser false en producción.

# Clave Pre-Alta (preferible en superadmin → Integraciones)
PRE_ALTA_INGEST_KEY=
PRE_ALTA_RETENTION_DAYS=20
PRE_ALTA_MAX_SECTIONS=50
PRE_ALTA_MAX_PRODUCTS_PER_SECTION=100
PRE_ALTA_MAX_PRODUCTS=500
# PRE_ALTA_ALLOWED_IMAGE_HOSTS=cdn.ejemplo.com,images.ejemplo.com

# API para app de digital signage (opcional: clave compartida con tu app)
DIGITAL_SIGNAGE_APP_KEY=
DIGITAL_SIGNAGE_ONLY_ENABLED=true

# TVPik — hub de publicación en pantallas (Plus o add-on Pro)
TVPIK_API_URL=
TVPIK_APP_KEY=
TVPIK_WEB_URL=https://tvpik.es
TVPIK_STUB_SCREENS=false

# Vídeos en platos (segundos y tamaño máximo en KB)
PRODUCT_MAX_VIDEO_SECONDS=30
PRODUCT_MAX_VIDEO_KB=25600
PRODUCT_VIDEO_MIMES=mp4,webm,mov,quicktime

# Escaneo de carta (Google Gemini) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
MENU_SCAN_SCANS_PER_HOUR=5
MENU_SCAN_PROVIDER=gemini
MENU_SCAN_FALLBACK=tesseract
# Ruta al bundle CA (por defecto resources/certs/cacert.pem). En Windows local suele ser necesario.
# MENU_SCAN_CA_BUNDLE=
# Solo desarrollo si sigue fallando SSL: MENU_SCAN_VERIFY_SSL=false
