# Gemini (solo en el worker; no en el servidor Webnu de producción)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Webnu (receptor pasivo)
WEBNU_BASE_URL=http://127.0.0.1:8000
WEBNU_DEMO_API_KEY=

# Límites de fetch
FETCH_TIMEOUT_MS=30000
FETCH_MAX_BYTES=10485760
CONCURRENCY=1

# Reintentos POST a Webnu
WEBNU_POST_RETRIES=2
WEBNU_POST_RETRY_DELAY_MS=1500
