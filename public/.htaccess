redirect 301 /cerveceria-el-parque-san-vicente-del-raspeig/ 	https://webnu.es/carta/cerveceria-el-parque
redirect 301 /hejiahuan-l-g-j-sl-2/	https://webnu.es/carta/bar-and-sushi
redirect 301 /hejiahuan-l-g-j-sl/	https://webnu.es/carta/bar-and-sushi
redirect 301 /hela2-jose-luis-gisbert-s-l/	https://webnu.es/carta/la-ibense
redirect 301 /los-casanueva/	https://webnu.es/carta/los-casanueva
redirect 301 /wanyuan/	https://webnu.es/carta/restaurante-wan-yuan
redirect 301 /wanyuan-2/	https://webnu.es/carta/restaurante-wan-yuan
